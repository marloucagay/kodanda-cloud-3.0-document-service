<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <style>
    html, body {
      box-sizing: border-box;
      font-family: Arial, Helvetica, sans-serif;
      color: #111;
      margin: 0;
    }
    .page {
      padding: 0 2mm;
      page-break-inside: avoid;
    }

    /* Grid */
    .grid2 {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 4px 22px;
      margin: 10px 0;
      font-size: 12px;
      margin-top: 15px;
    }

    .kv {
      display: flex;
      font-weight: 700;
    }

    .k {
      white-space: nowrap;
      font-weight: 700;
    }

    .underline {
      border-bottom: 1px solid #111;
      width: 100%;
      padding-left: 6px;
      font-weight: 400;
      display: inline-block;
      text-align: left;
    }

    /* Table */
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
      table-layout: fixed;
    }

    .items {
      margin-top: 15px;
    }

    .items th, .items td {
      border: 1px solid #111;
      padding: 6px;
    }

    .items tr {
      page-break-inside: avoid;
    }

    .qty, .unit {
      width: 60px;
      text-align: center;
      vertical-align: middle;
    }

    .particulars {
      text-align: center;
    }

    .part {
      line-height: 1.35;
      text-align: left;
      padding-left: 10px;
    }

    /* Pickup / Delivery */
    .pickup-header,
    .delivery-header {
    }

    .pickup-block,
    .delivery-block {
      display: flex;
      flex-direction: column;
      gap: 6px;
      padding: 8px;
    }

    .pickup-row,
    .delivery-row {
      display: flex;
      align-items: center;
      gap: 8px;
    }

  </style>
</head>

<body>
  <div class="page">
    <!-- Info -->
    <div class="grid2">
      <div class="kv">
        <div class="k">Client:</div>
        <div class="underline">{{client}}</div>
      </div>
      <div class="kv">
        <div class="k">Date:</div>
        <div class="underline">{{date}}</div>
      </div>
      <div class="kv">
        <div class="k">Shipment Reference:</div>
        <div class="underline">{{shipmentReference}}</div>
      </div>
      <div class="kv">
        <div class="k">File#:</div>
        <div class="underline">{{transactionFile}}</div>
      </div>
    </div>

    <!-- Table -->
    <table class="items">
      <thead>
        <tr>
          <th class="pickup-header" colspan="4">
            <div class="pickup-block">
              <div class="pickup-row">
                <span class="k">Pick-up Site:</span>
                <span class="underline">{{pickupSite}}</span>
              </div>
              <div class="pickup-row">
                <span class="k">Pick-up Address:</span>
                <span class="underline">{{pickupAddress}}</span>
              </div>
              <div class="pickup-row">
                <span class="k">Contact Person:</span>
                <span class="underline">{{pickupContactPerson}}</span>
              </div>
              <div class="pickup-row">
                <span class="k">Contact Number:</span>
                <span class="underline">{{pickupContactNumber}}</span>
              </div>
            </div>
          </th>

          <th class="delivery-header" colspan="4">
            <div class="delivery-block">
              <div class="delivery-row">
                <span class="k">Delivery Site:</span>
                <span class="underline">{{deliverySite}}</span>
              </div>
              <div class="delivery-row">
                <span class="k">Delivery Address:</span>
                <span class="underline">{{deliveryAddress}}</span>
              </div>
              <div class="delivery-row">
                <span class="k">Contact Person:</span>
                <span class="underline">{{deliveryContactPerson}}</span>
              </div>
              <div class="delivery-row">
                <span class="k">Contact Number:</span>
                <span class="underline">{{deliveryContactNumber}}</span>
              </div>
            </div>
          </th>
        </tr>

        <tr>
          <th class="qty">QTY.</th>
          <th class="unit">UNIT</th>
          <th class="particulars" colspan="6">PARTICULARS</th>
        </tr>
      </thead>

      <tbody>
        {{#items}}
        <tr>
          <td class="qty">{{qty}}</td>
          <td class="unit">{{unit}}</td>
          <td class="particulars" colspan="6">
            <div class="part">

              {{#description}}
              <div><b>Description:</b> {{description}}</div>
              {{/description}}

              {{#lot}}
              <div><b>Lot/Batch No.:</b> {{lot}}</div>
              {{/lot}}

              {{#expiryDate}}
              <div><b>Expiry Date:</b> {{expiryDate}}</div>
              {{/expiryDate}}

              {{#serialNo}}
              <div><b>Serial No.:</b> {{serialNo}}</div>
              {{/serialNo}}

            </div>
          </td>
        </tr>
        {{/items}}
      </tbody>
    </table>

  </div>
</body>
</html>