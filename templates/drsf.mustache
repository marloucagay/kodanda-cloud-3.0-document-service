<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <style>
    html, body {
      height: 100%;
      display: flex; 
      flex-direction: column; 
      justify-content: space-between; 
    }

    body > * {
      position: relative;
      z-index: 1;
    }
    body { font-family: Arial, Helvetica, sans-serif; color: #111; }
    table { width: 100%; border-collapse: collapse; margin-top: 10px; margin-bottom: 20px; }
    th, td { border: 1px solid #111; padding: 8px; }
    th { text-align: center; font-size: 12px; }
    td { font-size: 12px; }
    h4, h5 { margin: 0; }
    .drsf-row { height: 30px; }
  </style>
</head>
<body>
  <div>
    <div style="margin-top: -10px; display: flex; gap: 20px;">
      <table>
        <tbody>
          <tr>
            <td style="font-weight: 700;">Date</td>
            <td>{{date}}</td>
          </tr>
          <tr>
            <td style="font-weight: 700;">Client/Shipper</td>
            <td>{{clientShipper}}</td>
          </tr>
          <tr>
            <td style="font-weight: 700;">Consignee</td>
            <td>{{consignee}}</td>
          </tr>
          <tr>
            <td style="font-weight: 700;">Consignee's Address</td>
            <td>{{consigneeAddress}}</td>
          </tr>
          <tr>
            <td style="font-weight: 700; white-space: nowrap;">MDLI Delivery Receipt Number</td>
            <td>{{dRNo}}</td>
          </tr>
          <tr>
            <td style="font-weight: 700;">Total of Boxes</td>
            <td>{{numberOfBoxes}}</td>
          </tr>
        </tbody>
      </table>
      <div style="display: flex; margin-left: 15px; margin-right: 20px; white-space: nowrap; margin-top: 15px;">
        <h5>DRSF No.</h5>
        <h5 style="font-weight: 700; color: #c0392b; margin-left: 6px;">{{dRSFNo}}</h5>
      </div>
    </div>
    <h5>Cargo Dimensions</h5>
    <table>
      <thead>
        <tr>
          <th rowspan="2" style="text-align:center;">Box Number</th>
          <th colspan="3" style="text-align:center;">Dimension</th>
          <th colspan="3" style="text-align:center;">Weight</th>
          <th rowspan="2" style="text-align:center;">MDLI Boxes/Styro</th>
          <th rowspan="2" style="text-align:center;">Gell pack (pcs)</th>
          <th rowspan="2" style="text-align:center;">Dry Ice (kgs)</th>
        </tr>
        <tr>
          <th align="center">Length (cm)</th>
          <th align="center">Width (cm)</th>
          <th align="center">Height (cm)</th>
          <th align="center">Actual (kgs)</th>
          <th align="center">Volume</th>
          <th align="center">Chargeable</th>
        </tr>
      </thead>
      <tbody>
        {{#cargoDimensionsFirstPage}}
        <tr class="drsf-row">
          <td align="center">{{boxNumber}}</td>
          <td align="center">{{length}}</td>
          <td align="center">{{width}}</td>
          <td align="center">{{height}}</td>
          <td align="center">{{actual}}</td>
          <td align="center">{{volume}}</td>
          <td align="center">{{chargeable}}</td>
          <td align="start">{{mdliBoxesStyro}}</td>
          <td align="center">{{gellPack}}</td>
          <td align="center">{{dryIce}}</td>
        </tr>
        {{/cargoDimensionsFirstPage}}
      </tbody>
    </table>

    {{#cargoDimensionsRest.length}}
    <div style="page-break-before: always;"></div>
    <table>
      <thead>
        <tr>
          <th rowspan="2" style="text-align:center;">Box Number</th>
          <th colspan="3" style="text-align:center;">Dimension</th>
          <th colspan="3" style="text-align:center;">Weight</th>
          <th rowspan="2" style="text-align:center;">MDLI Boxes/Styro</th>
          <th rowspan="2" style="text-align:center;">Gell pack (pcs)</th>
          <th rowspan="2" style="text-align:center;">Dry Ice (kgs)</th>
        </tr>
        <tr>
          <th align="center">Length (cm)</th>
          <th align="center">Width (cm)</th>
          <th align="center">Height (cm)</th>
          <th align="center">Actual (kgs)</th>
          <th align="center">Volume</th>
          <th align="center">Chargeable</th>
        </tr>
      </thead>
      <tbody>
        {{#cargoDimensionsRest}}
        <tr class="drsf-row">
          <td align="center">{{boxNumber}}</td>
          <td align="center">{{length}}</td>
          <td align="center">{{width}}</td>
          <td align="center">{{height}}</td>
          <td align="center">{{actual}}</td>
          <td align="center">{{volume}}</td>
          <td align="center">{{chargeable}}</td>
          <td align="start">{{mdliBoxesStyro}}</td>
          <td align="center">{{gellPack}}</td>
          <td align="center">{{dryIce}}</td>
        </tr>
        {{/cargoDimensionsRest}}
      </tbody>
    </table>
    {{/cargoDimensionsRest.length}}
  </div>
</body>
</html>