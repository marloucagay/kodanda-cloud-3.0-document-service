<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <style>
    @page {
      size: {{pageWidthCm}}cm {{pageHeightCm}}cm;
      margin: 0;
    }

    body {
      margin: 0;
      font-family: Helvetica, Arial, sans-serif;
    }

    .page {
      position: relative;
      width: {{pageWidthCm}}cm;
      height: {{pageHeightCm}}cm;
      page-break-after: always;
    }

    .page:last-child {
      page-break-after: auto;
    }

    .field {
      position: absolute;
      font-size: 9px;
      white-space: pre-wrap;
    }
  </style>
</head>
<body>

{{#waybills}}
<div class="page">
 <div class="field" style="left:1.2cm; top:3.2cm; font-size:9px;">
    {{accountNumber}}
  </div>

  <div class="field" style="left:6cm; top:3.2cm;">
    {{billingReference}}
  </div>

  <div class="field" style="left:23cm; top:2.8cm; font-size:11px;">
    {{dRNumber}}
  </div>

  <!-- Pickup -->
  <div class="field" style="left:1.2cm; top:6.2cm;">
    {{waybillPickupSiteContactPerson}}
  </div>

  <div class="field" style="left:11.2cm; top:6.2cm;">
    {{waybillPickupSiteContactNumber}}
  </div>

  <div class="field" style="left:1.2cm; top:7.6cm; width:12cm;">
    {{waybillPickupSite}}
  </div>

  <div class="field" style="left:1.2cm; top:9cm; width:12cm;">
    {{waybillPickupSiteAddress}}
  </div>
  
   <div class="field" style="left:1.2cm; top:10.2cm; width:12cm;">
    {{waybillPickupSiteCity}}
  </div>
   <div class="field" style="left:4.2cm; top:10.2cm; width:12cm;">
    {{waybillPickupSiteCountry}}
  </div>
   <div class="field" style="left:7.2cm; top:10.2cm; width:12cm;">
    {{waybillPickupsitePostCode}}
  </div>

  <!-- Delivery -->
  <div class="field" style="left:15.2cm; top:6.2cm;">
    {{waybillDeliverySiteContactPerson}}
  </div>

  <div class="field" style="left:24cm; top:6.2cm;">
    {{waybillDeliverySiteContactNumber}}
  </div>

  <div class="field" style="left:15.2cm; top:7.6cm; width:12cm;">
    {{waybillDeliverySite}}
  </div>

  <div class="field" style="left:15.2cm; top:9cm; width:12cm;">
    {{waybillDeliverySiteAddress}}
  </div>
    <div class="field" style="left:15.2cm; top:10.2cm; width:12cm;">
    {{waybillDeliverySiteCity}}
  </div>
   <div class="field" style="left:18.2cm; top:10.2cm; width:12cm;">
    {{waybillDeliverySiteCountry}}
  </div>
   <div class="field" style="left:21.2cm; top:10.2cm; width:12cm;">
    {{waybillDeliverySitePostalCode}}
  </div>

  <!-- Cargo -->
  <div class="field" style="left:1.2cm; top:12.4cm;">
    {{waybillTypeOfCargo}}
  </div>

  <div class="field" style="left:15.2cm; top:12.4cm; ">
    {{waybillStorageTemperature}}
  </div>

   <div class="field" style="left:1.2cm; top:13.4cm;">
    {{waybillPcs}}
  </div>
   <div class="field" style="left:3.2cm; top:13.4cm;">
    {{waybillWeight}}
  </div>
   <div class="field" style="left:6.2cm; top:13.4cm;">
    {{waybillDimension}}
  </div>
 <!--countryOfOrigin-->
  <div class="field" style="left:1.2cm; top:14.4cm;">
    {{waybillDimension}}
  </div>

   <div class="field" style="left:6.2cm; top:14.4cm;">
    {{waybillDeclaredValue}}
  </div>

 <div class="field" style="left:1.2cm; top:15.4cm;">
    {{waybillShippersAgent}}
  </div>
  <div class="field" style="left:7.2cm; top:15.4cm;">
    {{waybillShippersAgentDate}}
  </div>

  <div class="field" style="left:13.2cm; top:15.4cm;">
    {{waybillConsigneeAgent}}
  </div>
    <div class="field" style="left:19.2cm; top:15.4cm;">
    {{waybillConsigneeAgentDate}}
  </div>
{{/waybills}}

</body>
</html>
