<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <style>
    html, body {
      height: 100%;
      display: flex; 
      flex-direction: column; 
      justify-content: space-between; 
      font-family: Arial, Helvetica, sans-serif;
      color: #414556;
    }

    .grid1 { display:grid; grid-template-columns: 1fr 3fr; margin: 6px 0; }
    .grid1 .k { font-size: 12px; white-space: nowrap; font-weight: 700; }
    .grid2 { display:grid; grid-template-columns: 1fr 1fr; gap: 6px 0;}
    .kv { display: grid; grid-template-columns: 1fr 1fr; }
    .kv .k { font-size: 12px; white-space: nowrap; font-weight: 700; }
    .data { font-size: 12px; width:100%; padding-left: 6px; }
    .remarks-section { width: 300px; display: flex; font-size: 12px; white-space: nowrap; padding: 10px 0; }
    .remarks-section .remarks { font-weight: 700; }
    .remarks-section .data { flex: 1; text-align: center; }

    .reasons-label { font-size: 12px; font-weight: 700; margin-bottom: 8px; }
    .chips { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }
    .chip {
      font-size: 11px;
      padding: 2px 10px;
      border: 1px solid #663399;
      color: #663399;
      border-radius: 999px;
      white-space: nowrap;
    }

    .adjustment-row {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 8px;
      padding: 6px 0;
      font-size: 12px;
    }
    .adj-label { font-weight: 700; margin-bottom: 2px; font-size: 11px; }
    .adj-value { font-size: 12px; }
    .adj-arrow { text-align: center; color: #663399; font-size: 14px; margin-right: 12px; }

    table { width:100%; border-collapse:collapse; margin-top: 10px; }
    th, td { border: 1px solid #111; padding: 6px; }
    th { text-align: start; font-size: 12px }
    td { font-size:12px }
    tr { page-break-inside: avoid; }
  </style>
</head>
<body>
    <div>
      <div class="grid2" style="margin-top: -10px;">
          <div class="kv">
              <div class="k">Adjustment ID:</div><div class="data">{{adjustmentID}}</div>
          </div>
          <div class="kv">
              <div class="k">Date:</div><div class="data">{{date}}</div>
          </div>
          <div class="kv">
              <div class="k">Created By #:</div><div class="data">{{createdBy}}</div>
          </div>
          <div class="kv">
              <div class="k">Status:</div><div class="data">{{status}}</div>
          </div>
          <div class="kv">
              <div class="k">Item Code:</div><div class="data">{{parentItemCode}}</div>
          </div>
          <div class="kv">
              <div class="k">Item Description:</div><div class="data">{{itemDescription}}</div>
          </div>
      </div>
      <div class="grid1">
          <div class="k">Client Name:</div><div class="data">{{clientName}}</div>
      </div>

      <div style="margin-top: 20px; border-top: 1px solid #e3e8ef; border-bottom: 1px solid #e3e8ef; padding: 10px 0 5px 0;">
        <div class="reasons-label">Adjustment Reasons:</div>
        <div class="chips">
          {{#selectedReasons}}
            <span class="chip">{{label}}</span>
          {{/selectedReasons}}
        </div>
      </div>

      <div style="margin-top: 6px;">
        {{#selectedReasons}}
          <div class="adjustment-row">
            <div class="grid2">
              <div class="adj-label">{{inputLabel}} :</div>
              <div class="adj-value">{{currentValue}}</div>
            </div>
            <div class="adj-arrow">&#8594;</div>
            <div class="grid2">
              <div class="adj-label">{{inputLabel}} New Value :</div>
              <div class="adj-value">{{newValue}}</div>
            </div>
          </div>
        {{/selectedReasons}}
      </div>

      <div class="remarks-section">
          <div class="remarks">Remarks: </div>
          <div class="data">{{remarks}}</div>
      </div>

    </div>
    
</body>
</html>